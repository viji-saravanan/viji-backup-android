# Copy this file to private.properties for local builds. The destination file is ignored by Git.
# Environment variables or Gradle -P properties with the documented names take precedence.

vijiBackup.driveUploadFolderId=your_shared_drive_folder_id
vijiBackup.allowedGoogleAccounts=allowed.user@example.test,alternate.user@example.test
vijiBackup.internalAndroidOAuthClientId=your_internal_android_oauth_client_id
vijiBackup.publicAndroidOAuthClientId=your_public_android_oauth_client_id
